{
    "version": "0.1.5",
    "description": "Personal engineering metrics, collected passively via git hooks",
    "homepage": "https://github.com/georgemandis/engsight",
    "license": "MIT",
    "notes": "Run 'engsight setup' after installing to set up ~/.engsight. Then 'engsight init' in your repos. MCP server requires Bun (https://bun.sh).",
    "url": "https://github.com/georgemandis/engsight/archive/refs/tags/v0.1.5.tar.gz",
    "hash": "0c5cbd3e8c9909a9a536894b05884da3b521c9629af2c0264b6eb2696ac07a10",
    "extract_dir": "engsight-0.1.5",
    "bin": "engsight",
    "post_install": [
        "$profileDir = Split-Path -Parent $PROFILE",
        "if (-not (Test-Path $profileDir)) { New-Item -ItemType Directory -Path $profileDir -Force | Out-Null }",
        "$marker = '# engsight completions'",
        "if (-not ((Test-Path $PROFILE) -and (Select-String -Path $PROFILE -SimpleMatch $marker -Quiet))) {",
        "    Add-Content -Path $PROFILE -Value \"`n$marker`nengsight completions powershell | Out-String | Invoke-Expression\"",
        "    Write-Host 'Registered engsight PowerShell completions in your $PROFILE (restart your shell to use them).' -ForegroundColor Green",
        "}",
        "Write-Host 'Run ''engsight setup'' to complete setup.' -ForegroundColor Yellow"
    ],
    "checkver": {
        "github": "https://github.com/georgemandis/engsight"
    },
    "autoupdate": {
        "url": "https://github.com/georgemandis/engsight/archive/refs/tags/v$version.tar.gz"
    }
}
